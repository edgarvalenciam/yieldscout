# URL pública del sitio (metadata Open Graph). En Vercel: Project → Settings → Environment Variables
# Ejemplo: https://yieldscout.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Opcional: webhook para reenviar POST de /api/feedback (Slack, Discord, Google Sheets, etc.)
# FEEDBACK_WEBHOOK_URL=

# Token gratuito para la API SIE de Banxico (CETES). https://www.banxico.org.mx/SieAPIRest/service/v1/token
# BANXICO_TOKEN=
